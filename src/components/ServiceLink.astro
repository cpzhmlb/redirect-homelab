---
import services from "../data/services.json";

interface Props {
  href: string;
  port: number;
  icon: string;
  name: string;
}

const { href, port, icon, name } = Astro.props;

const localUrl = `${services.localIp}:${port}`;
const tailscaleUrl = `${services.tailscaleIp}:${port}`;
---

<a 
  class="service-link" 
  target="_blank" 
  href={href}
  data-public-url={href}
  data-local-url={localUrl}
  data-tailscale-url={tailscaleUrl}
>
  <div class="service-link-content">
    <img class="service-icon" src={icon} alt={name} />
    {name}
  </div>
</a>

<style>
  .service-link {
    display: flex;
    align-items: center;
    gap: var(--gap, 16px);
    background: linear-gradient(135deg, rgba(var(--accent-rgb),0.06), rgba(255,255,255,0.02));
    padding: 14px 16px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--charcoal);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
    box-shadow: 0 8px 20px rgba(0,0,0,0.45);
    border: 1px solid rgba(255,255,255,0.03);
  }

  .service-link:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(0,0,0,0.5);
    border-color: rgba(255,255,255,0.04);
  }

  .service-link:active {
    transform: translateY(-2px) scale(0.995);
  }

  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    padding: 6px;
    background: rgba(0,0,0,0.35);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 6px 12px rgba(0,0,0,0.5);
    overflow: hidden;
    object-fit: contain;
  }

  .service-icon[src] {
    display: block;
  }

  .service-icon {
    width: 56px;
    height: 56px;
  }

  .service-link-content {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--charcoal);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .service-meta {
    font-weight: 600;
    color: var(--muted);
    font-size: 0.9rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-link,
    .service-link:hover,
    .service-link:active {
      transition: none;
      transform: none;
    }
  }
</style>