---
import "../styles/style.css";
import ServiceLink from "../components/ServiceLink.astro";
import services from "../data/services.json";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirect Homelab</title>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div class="app-container">
      <header
        class="page-head"
        style="display:flex;align-items:center;justify-content:space-between;gap:12px;"
      >
        <h1 class="header">Redirect Homelab</h1>
        <button
          class="theme-toggle"
          id="themeToggle"
          aria-label="Toggle theme"
          title="Toggle theme"
        >
          <!-- icon replaced dynamically by script -->
          <span id="themeIcon">🌙</span>
        </button>
      </header>

      <section class="card">
        <p>Public Services:</p>

        <div class="services-list public-services-list">
          {services.public.map((service) => <ServiceLink {...service} />)}
        </div>
      </section>

      <section class="card">
        <p>Private Services:</p>

        <div class="services-list private-services-list">
          {services.private.map((service) => <ServiceLink {...service} />)}
        </div>
      </section>
    </div>

    <style>
      /* Page-level tweaks that work with the global design system */
      .app-container {
        /* container sizing is handled globally, remove extra padding here */
        padding: 0;
      }

      .header {
        margin-bottom: 4px;
      }

      .card {
        margin-bottom: 28px;
      }

      .services-list {
        /* prefer the global grid but keep a sensible gap for tighter layouts */
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }

      /* slightly distinguish public vs private groups if needed */
      .public-services-list {
        margin-top: 6px;
      }
      .private-services-list {
        margin-top: 6px;
      }

      /* small footer area (styled in global CSS) */
      .app-footer {
        margin-top: 8px;
      }
    </style>

    <script>
      (function () {
        const root = document.documentElement;
        const KEY = "theme";
        const stored = localStorage.getItem(KEY);
        const prefersDark =
          window.matchMedia &&
          window.matchMedia("(prefers-color-scheme: dark)").matches;

        function applyTheme(name) {
          if (name === "dark") {
            root.setAttribute("data-theme", "dark");
          } else {
            root.removeAttribute("data-theme");
          }
        }

        function currentTheme() {
          return root.getAttribute("data-theme") === "dark" ? "dark" : "light";
        }

        function updateToggleIcon(theme) {
          const icon = document.getElementById("themeIcon");
          if (icon) {
            icon.textContent = theme === "dark" ? "☀️" : "🌙";
          }
        }

        function toggleTheme() {
          const now = currentTheme() === "dark" ? "light" : "dark";
          applyTheme(now);
          localStorage.setItem(KEY, now);
          updateToggleIcon(now);
        }

        // Initialize theme immediately (before DOM fully ready)
        const initialTheme = stored || (prefersDark ? "dark" : "light");
        applyTheme(initialTheme);

        // Since script is at end of body, DOM is ready - add listener directly
        const btn = document.getElementById("themeToggle");
        if (btn) {
          btn.addEventListener("click", toggleTheme);
        }

        // Update icon after a short delay to ensure element exists
        setTimeout(() => updateToggleIcon(currentTheme()), 0);
      })();
    </script>
  </body>
</html>
